{
  "users": [
    {
      "name": "guest",
      "password": "guest",
      "tags": ["administrator"]
    }
  ],
  "vhosts": [
    { "name": "/" }
  ],
  "permissions": [
    {
      "user": "guest",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "billing-events",
      "vhost": "/",
      "type": "fanout",
      "durable": true,
      "auto_delete": false
    },
    {
      "name": "audit-events",
      "vhost": "/",
      "type": "fanout",
      "durable": true,
      "auto_delete": false
    }
  ],
  "queues": [
    {
      "name": "audit-events-queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "billing-events",
      "vhost": "/",
      "destination": "audit-events",
      "destination_type": "exchange",
      "routing_key": "",
      "arguments": {}
    },
    {
      "source": "audit-events",
      "vhost": "/",
      "destination": "audit-events-queue",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    }
  ]
}
